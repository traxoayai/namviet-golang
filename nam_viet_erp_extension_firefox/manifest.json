{
  "manifest_version": 3,
  "name": "Đồng Bộ Hóa Đơn VAT Từ Tổng Cục Thuế",
  "version": "2.0",
  "description": "Auto-sync an toàn tuyệt đối với Giao diện nổi ngầm.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "cookies",
    "tabs",
    "downloads",
    "notifications"
  ],
  "host_permissions": [
    "https://hoadondientu.gdt.gov.vn/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.vercel.app/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Đồng Bộ Hóa Đơn VAT"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*.vercel.app/*",
        "https://hoadondientu.gdt.gov.vn/*"
      ],
      "js": ["content_v4.js"]
    }
  ]
}
