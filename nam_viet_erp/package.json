{
  "name": "nam_viet_erp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "dev": "vite",
    "dev:local": "vite --mode local",
    "dev:prod": "vite --mode production",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:rpc": "node scripts/run-vitest.mjs run --config vitest.config.integration.ts",
    "test:rpc:watch": "node scripts/run-vitest.mjs --config vitest.config.integration.ts",
    "typegen": "supabase gen types typescript --local --schema public > src/shared/types/database.types.ts",
    "test:types": "tsc --noEmit",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:unit": "node scripts/run-vitest.mjs run",
    "test:all": "npm run test:unit && npm run test:rpc && npm run test:e2e",
    "test:ci": "npm run test:unit && npm run test:rpc",
    "test:rpc:prod": "TEST_TARGET=prod node scripts/run-vitest.mjs run --config vitest.config.integration.ts",
    "api:gen": "openapi-typescript https://namviet-erp-backend-1051286041700.asia-southeast1.run.app/swagger/doc.json -o src/shared/types/api.types.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
