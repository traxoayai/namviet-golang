    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "antd": "^5.28.0",
    "axios": "^1.18.1",
    "dayjs": "^1.11.19",
    "dotenv": "^17.4.2",
    "firebase": "^12.5.0",
    "handlebars": "^4.7.8",
    "html5-qrcode": "^2.3.8",
    "jodit-react": "^5.2.38",
    "lodash": "^4.17.21",
    "lucide-react": "^0.562.0",
    "pdfjs-dist": "^5.4.530",
